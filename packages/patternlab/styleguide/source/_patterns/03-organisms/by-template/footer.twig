<footer data-nosnippet="true" class="ma__footer-new" id="footer">
  <div class="ma__footer-new__container">
    <div class="ma__footer-new__content-top">
      <div class="ma__footer-new__logo">
        {% include "@atoms/09-media/site-logo.twig" with {
          "sealImage": sealBlackImage
        } %}
      </div>
      <div class="ma__footer-new__state-organizations">
        <a href="{{ stateOrgsHref }}" class="direct-link">
          {{ icon('building', "20", "18") }}
          <span>State Organizations</span>
        </a>
      </div>
    </div>
    <div class="ma__footer-new__content">
      <nav class="ma__footer-new__navlinks" aria-label="site navigation">
        {% for link in footerLinksNew.links %}
          <div><a href="{{ link.href }}">{{ link.text }}</a></div>
        {% endfor %}
      </nav>
      <div class="ma__footer-new__copyright">
        <div class="ma__footer-new__copyright--bold">&copy; {{ "now"|date("Y") }} Commonwealth of Massachusetts.</div>
        <span>Mass.gov&#x00AE; is a registered service mark of the Commonwealth of Massachusetts.</span>
      </div>
    </div>
  </div>
</footer>

{% if floatingAction %}
  {% include "@atoms/01-buttons/fixed-feedback-button.twig" %}
{% endif %}
