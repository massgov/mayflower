<button type="button" class="ads-btn" data-modal-trigger="modal-large" aria-haspopup="dialog" aria-controls="modal-large">{{ modal.buttonText }}</button>
<div id="modal-large" class="ads-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-large-title">
    <div class="ads-modal-dialog ads-modal-large">
        <div class="ads-modal-header">
            <h2 id="modal-large-title" class="ads-modal-title">{{ modal.title }}</h2>
            <button type="button" class="ads-modal-close" aria-label="Close dialog">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                </svg>
            </button>
        </div>
        <div class="ads-modal-content">
            {{ modal.htmlContent }}
        </div>
        <div class="ads-modal-footer">
            <button type="button" class="ads-modal-btn-cancel">Cancel</button>
            <button type="button" class="ads-modal-btn-ok">OK</button>
        </div>
    </div>
</div>

